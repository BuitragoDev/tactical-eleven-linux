}

/* ------------------- RESUMEN JORNADA ------------------- */

.background-resumen-jornada {
    flex-grow: 1;
    width: 100%;
    height: 100%;
    background-color: rgb(180, 180, 180);
    position: absolute;
}

.resumen-jornada-cabecera-area {
    display: flex;
    flex-grow: 0;
    flex-direction: row;
    height: 10%;
    width: 100%;
    justify-content: center;
    align-items: center;
}

.resumen-jornada-titulo-area {
    height: 100%;
    width: auto;
    flex-grow: 1;
    justify-content: center;
    align-items: flex-start;
    background-color: rgb(24, 58, 39);
    padding-left: 20px;
}

.resumen-jornada-titulo {
    -unity-font-definition: resource("Fonts/Poppins-SemiBold");
    color: rgb(204, 201, 201);
    font-size: 48px;
}

.resumen-jornada-boton-area {
    height: 100%;
    width: 20%;
    flex-grow: 0;
    justify-content: center;
    align-items: center;
    background-color: rgb(180, 180, 180);
}

.lista-partidos-area {
    height: 94%;
